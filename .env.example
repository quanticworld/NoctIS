# NoctIS Configuration Example
# Copy this file to .env and adjust values as needed

# ClickHouse Connection Settings (Ultra-fast data warehouse)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=noctis_dev_clickhouse_password
CLICKHOUSE_DATABASE=noctis

# ClickHouse Performance Settings
# Batch size for bulk inserts (100k documents = optimal for native protocol)
CLICKHOUSE_BATCH_SIZE=100000
# Compression algorithm: lz4 (fast), zstd (better compression), none
CLICKHOUSE_COMPRESSION=lz4

# CORS Origins (comma-separated)
# Add your production server IP/domain here
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://192.168.1.44

# Search Defaults
DEFAULT_SEARCH_PATH=/
DEFAULT_THREADS=8
DEFAULT_MAX_FILESIZE=100M
MAX_THREADS=16

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30
