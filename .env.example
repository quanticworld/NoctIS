# NoctIS Configuration Example
# Copy this file to .env and adjust values as needed

# Meilisearch Connection Settings
MEILISEARCH_HOST=localhost
MEILISEARCH_PORT=7700
MEILISEARCH_MASTER_KEY=noctis_dev_meilisearch_key

# Connection timeout (in seconds)
# For large datasets (millions of documents), use 600+ seconds
MEILISEARCH_TIMEOUT=600

# Batch size for import operations (100k for high-speed async indexing)
# Lower values (10k-50k) for slower machines, higher (100k-200k) for fast imports
MEILISEARCH_BATCH_SIZE=100000

# Async mode: Don't wait for indexing to complete (MUCH faster, but no error tracking per batch)
# Set to false for safer imports with error tracking (slower)
MEILISEARCH_ASYNC_MODE=true

# CORS Origins (comma-separated)
# Add your production server IP/domain here
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://192.168.1.44

# Search Defaults
DEFAULT_SEARCH_PATH=/breaches
DEFAULT_THREADS=8
DEFAULT_MAX_FILESIZE=100M
MAX_THREADS=16

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30
